PORT=5000
MONGODB_URI=your_mongodb_connection_string
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=7d
CLIENT_URL=https://nexloglogistics.web.app
NODE_ENV=production

# Firebase Admin SDK — for Google Sign-In token verification
# Option A: Set this to the base64-encoded content of your Firebase service account JSON
# Run: base64 -i serviceAccountKey.json -o - | tr -d '\n' > key.txt
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_encoded_service_account_json

# Option B: Set the path to the service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
